      <origin rpy="1.570796 0 0" xyz="0 0 0"/>
      <geometry>
        <cylinder length="0.027" radius="0.033"/>
      </geometry>
    </collision>
  </link>
  <joint name="left_wheel_joint" type="continuous">
    <axis rpy="0 0 0" xyz="0 1 0"/>
    <parent link="base_link"/>
    <child link="left_wheel"/>
    <origin xyz="0.0605 0.1335 -0.04458"/>
  </joint>
  <link name="right_wheel">
    <inertial>
      <mass value="0.2"/>
      <inertia ixx="6.66e-05" ixy="0.0" ixz="0.0" iyy="6.66e-05" iyz="0.0" izz="0.00010890000000000002"/>
    </inertial>
    <visual>
      <origin rpy="1.570796 0 0" xyz="0 0 0"/>
      <geometry>
        <cylinder length="0.027" radius="0.033"/>
      </geometry>
      <material name="blue"/>
    </visual>
    <collision>
      <origin rpy="1.570796 0 0" xyz="0 0 0"/>
      <geometry>
        <cylinder length="0.027" radius="0.033"/>
      </geometry>
    </collision>
  </link>
  <joint name="right_wheel_joint" type="continuous">
    <axis rpy="0 0 0" xyz="0 1 0"/>
    <parent link="base_link"/>
    <child link="right_wheel"/>
    <origin xyz="0.0605 -0.1335 -0.04458"/>
  </joint>
  <link name="rear_wheel">
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="4.356000000000002e-05" ixy="0.0" ixz="0.0" iyy="4.356000000000002e-05" iyz="0.0" izz="4.356000000000002e-05"/>
    </inertial>
    <visual>
      <origin rpy="1.570796 0 0" xyz="0 0 0"/>
      <geometry>
        <sphere radius="0.033"/>
      </geometry>
      <material name="blue"/>
    </visual>
    <collision>
      <origin rpy="1.570796 0 0" xyz="0 0 0"/>
      <geometry>
        <sphere radius="0.033"/>
      </geometry>
    </collision>
  </link>
  <joint name="rear_wheel_joint" type="fixed">
    <parent link="base_link"/>
    <child link="rear_wheel"/>
    <origin xyz="-0.13 0 -0.04458"/>
  </joint>
  <!-- GAZEBO PHYSICS -->
  <gazebo reference="rear_wheel">
    <mu1>0.0</mu1>
    <mu2>0.0</mu2>
  </gazebo>
  <gazebo>
    <plugin filename="libgazebo_ros_diff_drive.so" name="diff_drive">
      <ros>
        <remapping>cmd_vel:=cmd_vel</remapping>
        <remapping>odom:=odom</remapping>
      </ros>
      <update_rate>50</update_rate>
      <left_joint>left_wheel_joint</left_joint>
      <right_joint>right_wheel_joint</right_joint>
      <wheel_separation>0.267</wheel_separation>
      <wheel_diameter>0.066</wheel_diameter>
      <max_wheel_acceleration>1.0</max_wheel_acceleration>
      <max_wheel_torque>20</max_wheel_torque>
      <command_topic>cmd_vel</command_topic>
      <publish_odom>true</publish_odom>
      <publish_odom_tf>true</publish_odom_tf>
      <publish_wheel_tf>true</publish_wheel_tf>
      <odometry_topic>odom</odometry_topic>
      <odometry_frame>odom</odometry_frame>
      <robot_base_frame>base_footprint</robot_base_frame>
    </plugin>
  </gazebo>
  <!-- BASE LINK -->
  <link name="base_link">
    <inertial>
      <mass value="5.0"/>
      <inertia ixx="0.04166666666666667" ixy="0.0" ixz="0.0" iyy="0.02083333333333334" iyz="0.0" izz="0.05416666666666667"/>
    </inertial>
    <visual>
      <origin rpy="0 0 3.14" xyz="0 0 0"/>
      <geometry>
        <mesh filename="package://urdf_tutorial/meshes/base_link.stl"/>
      </geometry>
    </visual>
    <collision>
      <geometry>
        <mesh filename="package://urdf_tutorial/meshes/base_link.stl"/>
      </geometry>
    </collision>
  </link>
  <!-- LIDAR -->
  <link name="laser">
    <visual>
      <origin xyz="0 0 0"/>
      <geometry>
        <cylinder length="0.02" radius="0.04"/>
      </geometry>
      <material name="blue"/>
    </visual>
  </link>
  <joint name="laser_joint" type="fixed">
    <parent link="base_link"/>
    <child link="laser"/>
    <origin rpy="0.0 0.0 0" xyz="0 0 0.11"/>
  </joint>
  <gazebo reference="laser">
    <sensor name="rplidar_sensor" type="ray">
      <pose>0 0 0 0 0 0</pose>
      <visualize>false</visualize>
      <update_rate>10</update_rate>
      <ray>
        <scan>
          <horizontal>
            <samples>360</samples>
            <resolution>1</resolution>
            <min_angle>-3.14159</min_angle>
            <max_angle>3.14159</max_angle>
          </horizontal>
        </scan>
        <range>
          <min>0.15</min>
          <max>10.0</max>
          <resolution>0.01</resolution>
        </range>
        <noise>
          <type>gaussian</type>
          <mean>0.0</mean>
          <stddev>0.01</stddev>
        </noise>
      </ray>
      <plugin filename="libgazebo_ros_ray_sensor.so" name="gazebo_ros_ray_sensor">
        <ros>
          <remapping>~/out:=scan</remapping>
        </ros>
        <output_type>sensor_msgs/LaserScan</output_type>
        <frame_name>laser</frame_name>
      </plugin>
    </sensor>
  </gazebo>
  <!-- TRAY LINK (Replacing arm) -->
  <link name="tray_link">
    <inertial>
      <mass value="0.5"/>
      <inertia ixx="0.002620833333333333" ixy="0.0" ixz="0.0" iyy="0.002620833333333333" iyz="0.0" izz="0.005208333333333333"/>
    </inertial>
    <visual>
      <geometry>
        <box size="0.25 0.25 0.02"/>
      </geometry>
      <material name="blue"/>
    </visual>
    <collision>
      <geometry>
        <box size="0.25 0.25 0.02"/>
      </geometry>
    </collision>
  </link>
  <joint name="tray_joint" type="fixed">
    <parent link="base_link"/>
    <child link="tray_link"/>
    <origin rpy="0 0 0" xyz="0 0 0.70"/>
  </joint>
  <!-- Because there are no more position/velocity controllable joints, 
       we do NOT include feetech.gazebo.xacro for gazebo_ros2_control. 
       The diff_drive plugin manages the wheels, and the rest is structural. -->
</robot>
