<robot name="feetech_tray">
  <material name="blue">
    <color rgba="0 0 0.8 1"/>
  </material>
  <link name="base_footprint"/>
  <joint name="base_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin rpy="0 0 0" xyz="0 0 0.05"/>
  </joint>
  <!-- WHEELS -->
  <link name="left_wheel">
    <inertial>
      <mass value="0.2"/>
      <inertia ixx="6.66e-05" ixy="0.0" ixz="0.0" iyy="6.66e-05" iyz="0.0" izz="0.00010890000000000002"/>
    </inertial>
    <visual>
